# Ask GeKo — local environment template.
#
# Copy this file to ".env" (same folder) and fill in your real key. The .env
# file is gitignored and must NEVER be committed. `netlify dev` loads it
# automatically; for production, set the same variables in the Netlify
# dashboard (Site settings -> Environment variables).

# Your OpenRouter API key (required). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug (optional). Defaults to google/gemini-2.5-flash if left unset.
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Vapi voice callback (callback + webhook functions) ---------------------
# Vapi account API key, the outbound phone-number id, and the assistant id.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=
# Shared secret we require in the x-vapi-secret header on the end-of-call
# webhook. Generate a strong random value (e.g. `openssl rand -base64 32`) and
# set the SAME value in Vapi's server-message settings.
VAPI_WEBHOOK_SECRET=

# --- Zoho CRM (INDIA data centre — accounts.zoho.in / www.zohoapis.in) ------
# From the Zoho API console (Self Client). CLIENT_ID/SECRET are permanent;
# GRANT_CODE is single-use and expires ~10 min — used once by
# scripts/zoho-token-exchange.mjs to mint the long-lived REFRESH_TOKEN.
# The webhook only needs CLIENT_ID, CLIENT_SECRET and REFRESH_TOKEN at runtime.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_GRANT_CODE=
ZOHO_REFRESH_TOKEN=
