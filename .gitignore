# build output
dist/
# dependencies
node_modules/
# Astro cache
.astro/
# environment secrets — never commit the OpenRouter key.
# Ignore every .env variant (.env, .env.local, .env.txt, ...) EXCEPT the
# committed, key-less template.
.env
.env.*
!.env.example
# Netlify local
.netlify/
# Netlify CLI artifacts (generated by `netlify dev`, not source)
deno.lock
public/.gitignore
# logs
*.log
npm-debug.log*
# exported chat logs (visitor Q&A — keep out of the repo)
chat-logs.csv
# OS / editor
.DS_Store
Thumbs.db
