---
// Shared site header. Sits on a light (bone) section: the gold compass
// mark on its light background, next to the firm wordmark, with page nav.
// Nav links are added only for pages that exist; more join as they're built.

// Mark the current page in the nav (and for screen readers). Astro gives us
// the request path; normalise trailing slashes so "/about/" matches "/about".
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';

const nav = [
  { href: '/about', label: 'About' },
  { href: '/partners', label: 'Partners' },
  { href: '/clients', label: 'Clients' },
  { href: '/articles', label: 'Articles' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Ask GeKo Advisory — home">
      <!-- Transparent compass mark — same brand mark used site-wide. -->
      <img class="brand-mark" src="/logo-transparent.png" alt="Ask GeKo Advisory compass logo" width="44" height="44" />
      <span class="brand-word">Ask GeKo Advisory</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { current: path === item.href }]}
          aria-current={path === item.href ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--bone);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 45%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    min-height: 72px;
  }

  /* --- Primary nav --- */
  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--mute-light);
    /* vertical padding gives a comfortable (>=24px) touch target */
    padding-block: 0.5rem;
    /* reserve space for the hover/current hairline so text doesn't shift */
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  /* Current page: thin gold underline. */
  .nav-link.current {
    color: var(--ink);
    border-bottom-color: var(--gold);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
  }

  .brand-mark {
    width: 44px;
    height: 44px;
    /* transparent PNG — sits cleanly on the bone bar, no blend needed */
    object-fit: contain;
  }

  .brand-word {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
</style>
