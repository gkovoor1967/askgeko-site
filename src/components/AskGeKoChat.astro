---
// Ask GeKo chat widget — a light panel holding the input and Send button.
// A static gold-serif caption sits below the panel until the visitor sends
// their first message; then the caption fades out and the conversation renders
// above the input inside the panel, scrolling internally (the page never
// scrolls). The caption is a label, NOT a chat message. No secrets client-side:
// the API key and model live only in the Netlify function's env vars.
// Single instance per page (it uses element IDs).
---

<div class="chat-widget">
  <div class="chat">
    <!-- Conversation — collapsed until the first message is sent. -->
    <div
      id="messages"
      class="messages is-empty"
      role="log"
      aria-live="polite"
      aria-label="Conversation with Ask GeKo"
    ></div>

    <form id="composer" class="composer">
      <label class="sr-only" for="ask-input">Your message</label>
      <textarea
        id="ask-input"
        rows="1"
        placeholder="Ask about leadership, strategy, or how we work…"
        autocomplete="off"
      ></textarea>
      <button id="send" type="submit">Send</button>
    </form>
  </div>

  <!-- Static gold-serif caption (a label, not a message). Fades on first send. -->
  <p id="chat-caption" class="chat-caption">Hello — I'm Ask GeKo. How can I help?</p>
</div>

<script>
  const form = document.getElementById('composer');
  const input = document.getElementById('ask-input');
  const log = document.getElementById('messages');
  const sendBtn = document.getElementById('send');
  const caption = document.getElementById('chat-caption');

  // Conversation state starts empty — the greeting is a static caption, not a
  // seeded message. The system prompt is added server-side only.
  const messages = [];
  let started = false;

  // Render a message. Uses textContent (not innerHTML) so nothing a visitor or
  // the model returns can inject markup.
  function addMessage(cssRole, content) {
    const el = document.createElement('div');
    el.className = 'msg ' + cssRole;
    el.textContent = content;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
    return el;
  }

  let pending = false;

  async function send(text) {
    const trimmed = text.trim();
    if (pending || !trimmed) return;

    // First message: reveal the conversation area and fade out the caption.
    if (!started) {
      started = true;
      log.classList.remove('is-empty');
      caption.classList.add('gone');
      setTimeout(() => { caption.style.display = 'none'; }, 450);
    }

    pending = true;
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage('user', trimmed);
    messages.push({ role: 'user', content: trimmed });

    const typing = addMessage('assistant typing', '…');

    try {
      const res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      });
      const data = await res.json().catch(() => ({}));
      typing.remove();

      if (!res.ok || !data.reply) {
        addMessage(
          'assistant',
          data.error ||
            "Sorry — I couldn't reach the assistant just now. Please try again, or email george@askgeko.com."
        );
      } else {
        addMessage('assistant', data.reply);
        messages.push({ role: 'assistant', content: data.reply });
      }
    } catch (err) {
      typing.remove();
      addMessage(
        'assistant',
        'Sorry — something went wrong reaching the assistant. Please try again, or email george@askgeko.com.'
      );
    } finally {
      pending = false;
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value;
    input.value = '';
    autoresize();
    send(text);
  });

  // Enter sends; Shift+Enter inserts a newline.
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.requestSubmit();
    }
  });

  // Gentle auto-resize of the textarea, up to a limit.
  function autoresize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }
  input.addEventListener('input', autoresize);

  // Shorten the placeholder on narrow screens. A textarea placeholder wraps
  // across lines (unlike <input>), so the long copy gets clipped mid-line in
  // the single-row box on a phone — swap in a short one that fits.
  const narrow = window.matchMedia('(max-width: 560px)');
  function setPlaceholder() {
    input.setAttribute(
      'placeholder',
      narrow.matches
        ? 'Ask me anything…'
        : 'Ask about leadership, strategy, or how we work…'
    );
  }
  setPlaceholder();
  narrow.addEventListener('change', setPlaceholder);
</script>

<style>
  .chat-widget {
    width: 100%;
    max-width: 40rem;
    margin-inline: auto;
  }

  /* Light panel on the dark screen. */
  .chat {
    border: 1px solid color-mix(in srgb, var(--gold) 35%, transparent);
    background: color-mix(in srgb, #fff 55%, var(--bone));
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
  }

  /* Conversation area — hidden until the first message, then bounded and
     internally scrollable so the page itself never scrolls. */
  .messages {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: clamp(1rem, 3vw, 1.4rem);
    /* Bounded so the expanded chat still fits one viewport under the larger
       brand block; longer conversations scroll internally. */
    max-height: min(19vh, 172px);
    overflow-y: auto;
  }

  .messages.is-empty {
    display: none;
  }

  /* NB: messages are created by JS at runtime, so they don't receive Astro's
     scoped-style attribute. Target them with :global(), kept local by the
     scoped `.messages` ancestor so nothing leaks outside this widget. */
  .messages :global(.msg) {
    max-width: 88%;
    padding: 0.6rem 0.95rem;
    line-height: 1.5;
  }

  /* Assistant = the firm speaking: serif, seated on a thin gold rule, left. */
  .messages :global(.msg.assistant) {
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--ink);
    border-left: 2px solid color-mix(in srgb, var(--gold) 70%, transparent);
  }

  .messages :global(.msg.typing) {
    color: var(--mute-light);
    letter-spacing: 0.15em;
  }

  /* Visitor = sans, right-aligned, on a quiet warm surface. */
  .messages :global(.msg.user) {
    align-self: flex-end;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background: var(--bone-2);
    border-radius: 2px;
    white-space: pre-wrap;
  }

  /* --- Composer (input + Send) --- */
  .composer {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    padding: 0.85rem;
    background: color-mix(in srgb, #fff 40%, var(--bone));
  }

  /* A hairline only appears once the conversation is visible above it. */
  .messages:not(.is-empty) + .composer {
    border-top: 1px solid color-mix(in srgb, var(--gold) 25%, transparent);
  }

  .composer textarea {
    flex: 1;
    resize: none;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 2px;
    padding: 0.6rem 0.75rem;
    max-height: 120px;
  }

  .composer textarea:focus-visible {
    outline: 2px solid var(--gold-deep);
    outline-offset: 1px;
  }

  .composer button {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bone);
    background: var(--ink);
    border: 1px solid var(--ink);
    padding: 0.7rem 1.4rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .composer button:hover:not(:disabled) {
    background: color-mix(in srgb, var(--ink) 82%, var(--gold));
  }

  .composer button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* Static gold-serif caption below the panel; fades out on first send. */
  .chat-caption {
    margin: 1.15rem 0 0;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.4vw, 1.4rem);
    color: var(--gold);
    transition: opacity 0.4s ease;
  }

  .chat-caption.gone {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .chat-caption {
      transition: none;
    }
  }

  /* Visually-hidden label, still read by screen readers. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
