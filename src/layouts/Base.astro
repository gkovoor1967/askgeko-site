---
// Base layout shared by every page: <head> (fonts, meta), header, page
// content via <slot />, and footer. Pages pass a title and description.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  // Fullscreen: exactly one viewport, no page scroll, no footer (the homepage).
  fullscreen?: boolean;
}

const {
  title = 'Ask GeKo Advisory — The Leadership Alchemists',
  description = 'A boutique management consultancy in Bengaluru, working with leaders on their most consequential decisions.',
  fullscreen = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />

    <!-- Favicons generated from the gold compass logo. -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Social share (Open Graph + Twitter). -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ask GeKo Advisory" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/apple-touch-icon.png', Astro.site)} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts: Cormorant Garamond (display) + Inter (body/UI), from Google Fonts. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class:list={[{ fullscreen }]}>
    <Header />
    <main>
      <slot />
    </main>
    {!fullscreen && <Footer />}
  </body>
</html>

<style>
  /* Full-height column so the footer sits at the bottom on short pages. */
  html, body { height: 100%; }
  body { display: flex; flex-direction: column; min-height: 100vh; }
  main { flex: 1 0 auto; }

  /* Fullscreen pages (homepage): lock to exactly one viewport, no page scroll.
     Header stays; main fills the remainder and its content scrolls internally. */
  body.fullscreen { height: 100dvh; min-height: 100dvh; overflow: hidden; }
  body.fullscreen main { flex: 1 1 auto; min-height: 0; }
</style>
