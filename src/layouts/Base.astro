---
// Base layout shared by every page: <head> (fonts, meta), header, page
// content via <slot />, and footer. Pages pass a title and description.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ask GeKo Advisory — The Leadership Alchemists',
  description = 'A boutique management consultancy in Bengaluru, working with leaders on their most consequential decisions.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/logo.jpg" />

    <!-- Fonts: Cormorant Garamond (display) + Inter (body/UI), from Google Fonts. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  /* Full-height column so the footer sits at the bottom on short pages. */
  html, body { height: 100%; }
  body { display: flex; flex-direction: column; min-height: 100vh; }
  main { flex: 1 0 auto; }
</style>
