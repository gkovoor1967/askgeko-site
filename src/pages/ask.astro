---
// Ask GeKo — the AI assistant page. A chat widget that POSTs the running
// conversation to the Netlify Function at /api/ask, which relays it to
// OpenRouter and returns a reply. No secrets here: the browser never sees the
// API key or model — those live in the function's environment variables.
//
// Per the brand: the assistant's replies render in the serif (the firm
// "speaking"); the visitor's messages render in the sans.
import Base from '../layouts/Base.astro';

// The opening greeting. Shown in the markup (so it reads even without JS) and
// seeded into the conversation state so the model has context.
const greeting =
  "Hello — I'm Ask GeKo. Tell me what you're weighing: a strategy to reset, a " +
  'transition to get right, a decision that cannot be undone. How can I help?';
---

<Base
  title="Ask GeKo — the assistant"
  description="Ask GeKo, the firm's AI advisor — think through a leadership or strategy question, or learn how we work."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Ask GeKo</p>
      <h1 class="page-title">Think it through with us.</h1>
      <p class="intro">
        A quiet place to test a leadership or strategy question, or to learn how
        the firm works. For a real engagement, we'll point you to a partner.
      </p>

      <!-- Chat panel -->
      <div class="chat">
        <div
          id="messages"
          class="messages"
          role="log"
          aria-live="polite"
          aria-label="Conversation with Ask GeKo"
          data-greeting={greeting}
        >
          <!-- Opening message, also present for no-JS visitors. -->
          <div class="msg assistant">{greeting}</div>
        </div>

        <form id="composer" class="composer">
          <label class="sr-only" for="ask-input">Your message</label>
          <textarea
            id="ask-input"
            rows="1"
            placeholder="Ask about leadership, strategy, or how we work…"
            autocomplete="off"
          ></textarea>
          <button id="send" type="submit">Send</button>
        </form>
      </div>

      <!-- "Go further" — hand off to a partner by leaving details.
           This is a Netlify Form: at deploy time Netlify detects the form
           from the built HTML (the data-netlify attribute + hidden form-name),
           captures each submission, and emails it to george@askgeko.com once
           an email notification is configured in the Netlify dashboard.
           Progressive enhancement: the script below submits without leaving
           the page; with JS off, the plain POST still works via Netlify's
           own success page. -->
      <section class="handoff-wrap" aria-labelledby="handoff-title">
        <h2 id="handoff-title" class="handoff-title">Go further</h2>
        <p class="handoff-intro">
          Want real help on a specific decision? Leave your details and a
          partner will follow up — or write to
          <a href="mailto:george@askgeko.com?subject=Ask%20GeKo%20enquiry">george@askgeko.com</a>.
        </p>

        <form
          name="go-further"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          id="handoff"
          class="handoff"
        >
          <!-- Netlify needs this hidden field to match the submission. -->
          <input type="hidden" name="form-name" value="go-further" />
          <!-- Honeypot: hidden from people, catches spam bots. -->
          <p class="hp" aria-hidden="true">
            <label>Leave this field empty <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>

          <div class="field">
            <label for="hf-name">Name</label>
            <input id="hf-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="hf-email">Email</label>
            <input id="hf-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="field">
            <label for="hf-question">What would you like help with?</label>
            <textarea id="hf-question" name="question" rows="3" required></textarea>
          </div>

          <button type="submit">Send to the team</button>
          <p class="handoff-status" id="handoff-status" role="status" aria-live="polite"></p>
        </form>
      </section>
    </div>
  </section>
</Base>

<script>
  // --- Ask GeKo chat widget ---------------------------------------------
  const form = document.getElementById('composer');
  const input = document.getElementById('ask-input');
  const log = document.getElementById('messages');
  const sendBtn = document.getElementById('send');

  // Conversation state. Seed with the greeting already shown in the markup so
  // the model has context. The system prompt is added server-side only.
  const messages = [{ role: 'assistant', content: log.dataset.greeting || '' }];

  // Render a message and scroll it into view. Uses textContent (not innerHTML)
  // so nothing a visitor or the model returns can inject markup.
  function addMessage(cssRole, content) {
    const el = document.createElement('div');
    el.className = 'msg ' + cssRole;
    el.textContent = content;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
    return el;
  }

  let pending = false;

  async function send(text) {
    const trimmed = text.trim();
    if (pending || !trimmed) return;

    pending = true;
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage('user', trimmed);
    messages.push({ role: 'user', content: trimmed });

    const typing = addMessage('assistant typing', '…');

    try {
      const res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages }),
      });
      const data = await res.json().catch(() => ({}));
      typing.remove();

      if (!res.ok || !data.reply) {
        addMessage(
          'assistant',
          data.error ||
            "Sorry — I couldn't reach the assistant just now. Please try again, or email george@askgeko.com."
        );
      } else {
        addMessage('assistant', data.reply);
        messages.push({ role: 'assistant', content: data.reply });
      }
    } catch (err) {
      typing.remove();
      addMessage(
        'assistant',
        'Sorry — something went wrong reaching the assistant. Please try again, or email george@askgeko.com.'
      );
    } finally {
      pending = false;
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const text = input.value;
    input.value = '';
    autoresize();
    send(text);
  });

  // Enter sends; Shift+Enter inserts a newline.
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      form.requestSubmit();
    }
  });

  // Gentle auto-resize of the textarea, up to a limit.
  function autoresize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 160) + 'px';
  }
  input.addEventListener('input', autoresize);

  // --- "Go further" Netlify Form -----------------------------------------
  // Submit via fetch so the visitor stays on the page. Netlify accepts the
  // form-encoded POST (including form-name) at any site path. If JS fails,
  // the plain form still submits to Netlify's default success page.
  const handoff = document.getElementById('handoff');
  const handoffStatus = document.getElementById('handoff-status');

  handoff.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = handoff.querySelector('button[type="submit"]');
    btn.disabled = true;
    handoffStatus.textContent = 'Sending…';

    try {
      const body = new URLSearchParams(new FormData(handoff)).toString();
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      });
      if (res.ok) {
        handoff.reset();
        handoffStatus.textContent = "Thank you — we'll be in touch shortly.";
      } else {
        handoffStatus.textContent = 'Something went wrong. Please email george@askgeko.com.';
        btn.disabled = false;
      }
    } catch (err) {
      handoffStatus.textContent = 'Something went wrong. Please email george@askgeko.com.';
      btn.disabled = false;
    }
  });
</script>

<style>
  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .page-title {
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    color: var(--ink);
    margin: 0.75rem 0 0;
  }

  .intro {
    max-width: 52ch;
    color: var(--mute-light);
    font-size: 1.05rem;
    margin: 1rem 0 0;
  }

  /* --- Chat panel --- */
  .chat {
    margin-top: clamp(2rem, 5vw, 3rem);
    max-width: 46rem;
    border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    background: color-mix(in srgb, #fff 45%, var(--bone));
  }

  .messages {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    min-height: 220px;
    max-height: 52vh;
    overflow-y: auto;
  }

  /* Shared message block. */
  .msg {
    max-width: 88%;
    padding: 0.7rem 1rem;
    line-height: 1.5;
  }

  /* Assistant = the firm speaking: serif, seated on a thin gold rule, left. */
  .msg.assistant {
    align-self: flex-start;
    font-family: var(--font-display);
    font-size: 1.18rem;
    color: var(--ink);
    border-left: 2px solid color-mix(in srgb, var(--gold) 70%, transparent);
  }

  .msg.typing {
    color: var(--mute-light);
    letter-spacing: 0.15em;
  }

  /* Visitor = sans, right-aligned, on a quiet warm surface. */
  .msg.user {
    align-self: flex-end;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background: var(--bone-2);
    border-radius: 2px;
    white-space: pre-wrap; /* preserve any newlines the visitor typed */
  }

  /* --- Composer --- */
  .composer {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    padding: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--gold) 25%, transparent);
    background: color-mix(in srgb, #fff 30%, var(--bone));
  }

  .composer textarea {
    flex: 1;
    resize: none;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 2px;
    padding: 0.6rem 0.75rem;
    max-height: 160px;
  }

  .composer textarea:focus-visible {
    outline: 2px solid var(--gold-deep);
    outline-offset: 1px;
  }

  .composer button {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bone);
    background: var(--ink);
    border: 1px solid var(--ink);
    padding: 0.7rem 1.4rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .composer button:hover:not(:disabled) {
    background: transparent;
    color: var(--ink);
  }

  .composer button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  /* --- "Go further" handoff form --- */
  .handoff-wrap {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    max-width: 46rem;
    padding-top: clamp(2rem, 5vw, 3rem);
    border-top: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
  }

  .handoff-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--ink);
    margin: 0;
  }

  .handoff-intro {
    max-width: 52ch;
    color: var(--mute-light);
    font-size: 1rem;
    margin: 0.5rem 0 1.75rem;
  }

  .handoff-intro a {
    color: var(--gold-deep);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 55%, transparent);
    padding-bottom: 1px;
  }

  /* Honeypot field — present in the DOM for bots, hidden from people. */
  .hp {
    display: none;
  }

  .handoff .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.1rem;
  }

  .handoff label {
    font-family: var(--font-body);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--mute-light);
  }

  .handoff input,
  .handoff textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink);
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    border-radius: 2px;
    padding: 0.6rem 0.75rem;
    width: 100%;
  }

  .handoff textarea {
    resize: vertical;
    min-height: 4.5rem;
  }

  .handoff input:focus-visible,
  .handoff textarea:focus-visible {
    outline: 2px solid var(--gold-deep);
    outline-offset: 1px;
  }

  .handoff button {
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bone);
    background: var(--ink);
    border: 1px solid var(--ink);
    padding: 0.7rem 1.4rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .handoff button:hover:not(:disabled) {
    background: transparent;
    color: var(--ink);
  }

  .handoff button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .handoff-status {
    margin: 0.9rem 0 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--gold-deep);
    min-height: 1.3em;
  }

  /* Visually-hidden label, still read by screen readers. */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
