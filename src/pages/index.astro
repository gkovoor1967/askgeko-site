---
// Home — a single full-viewport dark screen that never scrolls. The brand
// (compass mark, wordmark, tagline, positioning line) sits upper-middle; the
// Ask GeKo chat widget sits lower-centre with a static gold caption below it.
// No featured section — this page is one screen only.
import Base from '../layouts/Base.astro';
import AskGeKoChat from '../components/AskGeKoChat.astro';
---

<Base fullscreen>
  <section class="screen">
    <div class="brand-block">
      <img
        class="hero-mark"
        src="/logo-transparent.png"
        alt="Ask GeKo Advisory — gold compass logo"
        width="329"
        height="348"
      />
      <h1 class="wordmark">Ask GeKo Advisory</h1>
      <p class="tagline">The Leadership Alchemists</p>
      <hr class="rule-gold hero-rule" />
      <p class="positioning">
        We help leaders and organisations tackle their hardest decisions
        — and turn them into lasting advantage.
      </p>
    </div>

    <div class="chat-block">
      <AskGeKoChat />
    </div>
  </section>
</Base>

<style>
  /* One screen, dark ink, no scroll. Brand and chat are centred as a group
     with a generous gap so the brand reads upper-middle and the chat lower. */
  .screen {
    height: 100%;
    min-height: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.75rem, 6vh, 4rem);
    padding: clamp(1.25rem, 3vh, 2.5rem) var(--page-pad);
    text-align: center;
    color: var(--bone);
    background: var(--ink);
    background-image: radial-gradient(
      62% 55% at 50% 40%,
      var(--ink-2) 0%,
      var(--ink) 72%
    );
    overflow: hidden;
  }

  /* --- Brand (upper-middle) --- */
  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: rise 1.1s ease-out both;
  }

  .hero-mark {
    width: clamp(52px, 7.5vh, 76px);
    height: auto;
    margin: 0 auto 0.85rem;
    filter: drop-shadow(0 10px 24px rgba(0, 0, 0, 0.55));
  }

  .wordmark {
    font-size: clamp(1.8rem, 4.4vw, 2.7rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--bone);
    margin: 0;
  }

  .tagline {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: clamp(0.66rem, 1.5vw, 0.78rem);
    color: var(--gold);
    margin: 0.6rem 0 0;
    padding-left: 0.3em;
  }

  .hero-rule {
    width: 64px;
    margin: 0.85rem auto;
  }

  .positioning {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.9vw, 1.3rem);
    line-height: 1.35;
    color: var(--mute-dark);
    max-width: 30rem;
    margin: 0 auto;
  }

  /* --- Chat (lower-centre) --- */
  .chat-block {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-block {
      animation: none;
    }
  }
</style>
