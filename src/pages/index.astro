---
// Home — a single full-viewport dark screen that never scrolls. The brand
// (compass mark, wordmark, tagline, positioning line) sits upper-middle; the
// Ask GeKo chat widget sits lower-centre with a static gold caption below it.
// No featured section — this page is one screen only.
import Base from '../layouts/Base.astro';
import AskGeKoChat from '../components/AskGeKoChat.astro';
---

<Base fullscreen>
  <section class="screen">
    <div class="brand-block">
      <img
        class="hero-mark"
        src="/logo-transparent.png"
        alt="Ask GeKo Advisory — gold compass logo"
        width="329"
        height="348"
      />
      <h1 class="wordmark">Ask GeKo Advisory</h1>
      <p class="tagline">The Leadership Alchemists</p>
      <hr class="rule-gold hero-rule" />
      <p class="positioning">
        We help leaders and organisations tackle their hardest decisions
        — and turn them into lasting advantage.
      </p>
    </div>

    <div class="chat-block">
      <AskGeKoChat />
    </div>
  </section>
</Base>

<style>
  /* One screen, dark ink, no scroll. Brand and chat are centred as a group
     with a generous gap so the brand reads upper-middle and the chat lower. */
  .screen {
    height: 100%;
    min-height: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(1.5rem, 4vh, 3rem) var(--page-pad) clamp(2rem, 5vh, 3.5rem);
    text-align: center;
    color: var(--bone);
    background: var(--ink);
    background-image: radial-gradient(
      62% 55% at 50% 38%,
      var(--ink-2) 0%,
      var(--ink) 72%
    );
    overflow: hidden;
  }

  /* --- Brand: breathes in the upper two-thirds --- */
  .brand-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: clamp(0.5rem, 5vh, 3.5rem);
    animation: rise 1.1s ease-out both;
  }

  /* Large compass mark — restores the presence of the earlier full hero. */
  .hero-mark {
    width: clamp(128px, 17vh, 156px);
    height: auto;
    margin: 0 auto 1.4rem;
    filter: drop-shadow(0 14px 32px rgba(0, 0, 0, 0.55));
  }

  .wordmark {
    font-size: clamp(1.9rem, 4.6vw, 2.9rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--bone);
    margin: 0;
  }

  .tagline {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: clamp(0.68rem, 1.5vw, 0.8rem);
    color: var(--gold);
    margin: 0.85rem 0 0;
    padding-left: 0.3em;
  }

  .hero-rule {
    width: 72px;
    margin: 1.3rem auto;
  }

  .positioning {
    font-family: var(--font-display);
    font-size: clamp(1.02rem, 1.9vw, 1.32rem);
    line-height: 1.4;
    color: var(--mute-dark);
    max-width: 32rem;
    margin: 0.3rem auto 0;
  }

  /* --- Chat: pinned to the bottom third; grows upward on send --- */
  .chat-block {
    width: 100%;
    display: flex;
    justify-content: center;
    margin-top: auto;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-block {
      animation: none;
    }
  }
</style>
