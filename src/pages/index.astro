---
// Home — full-height dark hero. The first screen of the site:
// the compass mark, the firm name, the tagline, one positioning line,
// and a thin gold rule. Restraint over decoration.
//
// Copy is taken verbatim from askgeko-content.md:
//   tagline         — "The Leadership Alchemists"
//   positioning line — the hero sentence
//
// Below the hero sit two quiet sections: an Ask GeKo teaser and a featured
// insight (the newest article), each a restrained invitation deeper into the
// site — no embedded chat, no clutter.
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Newest article, sorted the same way as the Articles page.
const latest = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)[0];
---

<Base>
  <section class="hero">
    <div class="hero-inner">
      <!-- Gold compass mark on a transparent ground, sitting directly on the
           dark hero (white background removed from the source logo). -->
      <img
        class="hero-mark"
        src="/logo-transparent.png"
        alt="Ask GeKo Advisory — gold compass logo"
        width="329"
        height="348"
      />

      <h1 class="wordmark">Ask GeKo Advisory</h1>
      <p class="tagline">The Leadership Alchemists</p>

      <hr class="rule-gold hero-rule" />

      <p class="positioning">
        We help leaders and organisations tackle their hardest decisions
        — and turn them into lasting advantage.
      </p>
    </div>
  </section>

  <!-- Ask GeKo teaser — a quiet invitation, not the chat itself. -->
  <section class="home-section ask-teaser">
    <div class="container">
      <p class="eyebrow">Ask GeKo</p>
      <p class="teaser-line">Have a question worth a considered answer?</p>
      <p class="teaser-support">
        Put it to Ask GeKo — the firm's AI advisor — and think it through,
        privately and without obligation.
      </p>
      <a class="gold-link" href="/ask">
        Think it through with us
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- Featured insight — the most recent article, linking into /articles. -->
  {latest && (
    <section class="home-section latest">
      <div class="container">
        <p class="eyebrow">Latest thinking</p>
        <a class="latest-link" href="/articles">
          <h2 class="latest-title">{latest.data.title}</h2>
          <p class="latest-excerpt">{latest.data.excerpt}</p>
          <span class="gold-link as-cue">
            Read the latest thinking
            <span class="arrow" aria-hidden="true">→</span>
          </span>
        </a>
      </div>
    </section>
  )}
</Base>

<style>
  /* Full-height dark hero, sitting just below the light header bar. */
  .hero {
    min-height: calc(100dvh - 73px); /* viewport minus the 72px header + 1px rule */
    display: grid;
    place-items: center;
    text-align: center;
    padding: 4rem var(--page-pad);
    color: var(--bone);
    background: var(--ink);
    /* A single, very quiet pool of light behind the mark — no gradients loud
       enough to notice, just enough to lift the composition off flat black. */
    background-image: radial-gradient(
      60% 55% at 50% 38%,
      var(--ink-2) 0%,
      var(--ink) 70%
    );
  }

  .hero-inner {
    max-width: 46rem;
    /* One slow load rise — no bounce; disabled under prefers-reduced-motion. */
    animation: hero-rise 1.1s ease-out both;
  }

  /* Compass mark, transparent PNG directly on the dark ground. A soft
     drop-shadow lifts it without the old white "coin". */
  .hero-mark {
    width: clamp(120px, 16vw, 156px);
    height: auto;
    margin: 0 auto 2rem;
    filter: drop-shadow(0 12px 30px rgba(0, 0, 0, 0.55));
  }

  .wordmark {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--bone);
    margin: 0;
  }

  /* Tagline in the eyebrow style — uppercase, widely tracked, gold. */
  .tagline {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: clamp(0.72rem, 1.6vw, 0.85rem);
    color: var(--gold);
    margin: 1rem 0 0;
    /* nudge for optical centring of tracked text */
    padding-left: 0.3em;
  }

  .hero-rule {
    width: 88px;
    margin: 2rem auto;
  }

  .positioning {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    line-height: 1.45;
    color: var(--mute-dark);
    max-width: 34rem;
    margin: 0 auto;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* --- Quiet sections below the hero --- */
  .home-section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  /* Second section on the secondary warm surface + a thin gold hairline,
     to separate it from the teaser without adding weight. */
  .home-section.latest {
    background: var(--bone-2);
    border-top: 1px solid color-mix(in srgb, var(--gold) 25%, transparent);
  }

  /* Ask GeKo teaser */
  .teaser-line {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.6vw, 2.4rem);
    line-height: 1.2;
    color: var(--ink);
    max-width: 24ch;
    margin: 1rem 0 0;
  }

  .teaser-support {
    max-width: 46ch;
    color: var(--mute-light);
    font-size: 1.05rem;
    margin: 0.85rem 0 0;
  }

  /* Shared gold call-to-action link — understated, arrow nudges on hover. */
  .gold-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--gold-deep);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 55%, transparent);
    padding-bottom: 3px;
  }

  .arrow {
    transition: transform 0.2s ease;
  }

  .gold-link:hover .arrow,
  .gold-link:focus-visible .arrow,
  .latest-link:hover .arrow,
  .latest-link:focus-visible .arrow {
    transform: translateX(4px);
  }

  /* Featured insight */
  .latest-link {
    display: block;
    max-width: 68ch;
  }

  .latest-title {
    font-size: clamp(1.5rem, 3.2vw, 2.1rem);
    color: var(--ink);
    margin: 1rem 0 0;
    transition: color 0.2s ease;
  }

  .latest-excerpt {
    color: var(--mute-light);
    font-size: 1.05rem;
    margin: 0.75rem 0 0;
  }

  /* When used as the cue inside the article link, the arrow still nudges but
     the margin matches the block's rhythm. */
  .as-cue {
    margin-top: 1.25rem;
  }

  .latest-link:hover .latest-title,
  .latest-link:focus-visible .latest-title {
    color: var(--gold-deep);
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow {
      transition: none;
    }
  }
</style>
