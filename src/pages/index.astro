---
// Home — full-height dark hero. The first screen of the site:
// the compass mark, the firm name, the tagline, one positioning line,
// and a thin gold rule. Restraint over decoration.
//
// Copy is taken verbatim from askgeko-content.md:
//   tagline         — "The Leadership Alchemists"
//   positioning line — the hero sentence
import Base from '../layouts/Base.astro';
---

<Base>
  <section class="hero">
    <div class="hero-inner">
      <!-- Gold compass mark, seated on a light medallion so it reads
           cleanly on the dark hero. Swap to a transparent PNG at step 8. -->
      <div class="medallion">
        <img
          src="/logo.jpg"
          alt="Ask GeKo Advisory compass logo"
          width="132"
          height="132"
        />
      </div>

      <h1 class="wordmark">Ask GeKo Advisory</h1>
      <p class="tagline">The Leadership Alchemists</p>

      <hr class="rule-gold hero-rule" />

      <p class="positioning">
        We help leaders and organisations tackle their hardest decisions
        — and turn them into lasting advantage.
      </p>
    </div>
  </section>
</Base>

<style>
  /* Full-height dark hero, sitting just below the light header bar. */
  .hero {
    min-height: calc(100dvh - 73px); /* viewport minus the 72px header + 1px rule */
    display: grid;
    place-items: center;
    text-align: center;
    padding: 4rem var(--page-pad);
    color: var(--bone);
    background: var(--ink);
    /* A single, very quiet pool of light behind the mark — no gradients loud
       enough to notice, just enough to lift the composition off flat black. */
    background-image: radial-gradient(
      60% 55% at 50% 38%,
      var(--ink-2) 0%,
      var(--ink) 70%
    );
  }

  .hero-inner {
    max-width: 46rem;
    /* One slow load rise — no bounce; disabled under prefers-reduced-motion. */
    animation: hero-rise 1.1s ease-out both;
  }

  /* Logo medallion — a small white "coin" ringed with a gold hairline. */
  .medallion {
    width: clamp(104px, 14vw, 132px);
    aspect-ratio: 1;
    margin: 0 auto 2rem;
    border-radius: 50%;
    background: #fff;
    display: grid;
    place-items: center;
    /* thin gold ring + soft lift off the dark ground */
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--gold) 60%, transparent),
      0 18px 48px rgba(0, 0, 0, 0.5);
  }

  .medallion img {
    width: 78%;
    height: 78%;
    border-radius: 50%; /* clip the square corners to the compass circle */
    object-fit: cover;
  }

  .wordmark {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    font-weight: 500;
    letter-spacing: 0.005em;
    color: var(--bone);
    margin: 0;
  }

  /* Tagline in the eyebrow style — uppercase, widely tracked, gold. */
  .tagline {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: clamp(0.72rem, 1.6vw, 0.85rem);
    color: var(--gold);
    margin: 1rem 0 0;
    /* nudge for optical centring of tracked text */
    padding-left: 0.3em;
  }

  .hero-rule {
    width: 88px;
    margin: 2rem auto;
  }

  .positioning {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    line-height: 1.45;
    color: var(--mute-dark);
    max-width: 34rem;
    margin: 0 auto;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
