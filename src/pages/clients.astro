---
// Clients — a refined name wall, gold hairline separators. Named clients
// only, no project details (per permissions). Order and names verbatim from
// askgeko-content.md: lead with Diageo. Arthur D. Little is deliberately
// excluded until the work is done — do not add it back without George's word.
import Base from '../layouts/Base.astro';

const clients = [
  'United Spirits Limited (Diageo)',
  'Apax',
  'Beyond Snack',
  'Canadian Crystalline',
  'AlgoSynth',
];
---

<Base
  title="Clients — Ask GeKo Advisory"
  description="Trusted by leaders across consumer, private equity, and industry."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Clients</p>
      <p class="intro">
        Trusted by leaders across consumer, private equity, and industry.
      </p>

      <!-- Name wall: each client on its own line, divided by gold hairlines. -->
      <ul class="wall">
        {clients.map((name) => (
          <li>{name}</li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .intro {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.3;
    color: var(--ink);
    max-width: 34ch;
    margin: 1rem 0 0;
  }

  .wall {
    list-style: none;
    margin: clamp(2.5rem, 6vw, 4rem) 0 0;
    padding: 0;
    /* A gold hairline closes off the bottom of the wall. */
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 35%, transparent);
  }

  .wall li {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    color: var(--ink);
    padding-block: clamp(1.1rem, 3vw, 1.6rem);
    /* Gold hairline separator above each name. */
    border-top: 1px solid color-mix(in srgb, var(--gold) 35%, transparent);
  }
</style>
