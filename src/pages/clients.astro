---
// Clients — a single horizontal layer of client logos, organised into three
// groups (Consumer · Private Equity · B2B & Technology) divided by thin gold
// hairlines. Named clients only, no project details (per permissions). Order
// verbatim from askgeko-content.md: Diageo leads. Arthur D. Little is
// deliberately excluded until the work is done — do not add it back without
// George's word.
//
// Each logo has a mixed background/resolution, so every logo sits in an
// identical fixed-height zone, multiply-blended (drops white grounds into the
// card) and rendered greyscale, with colour restored on hover. On desktop all
// five sit in one row; on mobile the three groups stack with their headers.
import Base from '../layouts/Base.astro';

const groups = [
  {
    header: 'Consumer',
    clients: [
      { name: 'United Spirits Limited (Diageo)', label: 'Alcobev',       logo: '/diageo-india.png' },
      { name: 'Beyond Snack',                    label: 'FMCG Snacking',  logo: '/beyond-snack.png' },
    ],
  },
  {
    header: 'Private Equity',
    clients: [
      { name: 'Apax', label: '', logo: '/apax.png' },
    ],
  },
  {
    header: 'B2B & Technology',
    clients: [
      { name: 'Canadian Crystalline', label: 'Water & Beverage Equipment', logo: '/canadian-crystalline.png' },
      { name: 'AlgoSynth',            label: 'Sweetener Technologies',      logo: '/algosynth.png' },
    ],
  },
];
---

<Base
  title="Clients — Ask GeKo Advisory"
  description="Trusted by leaders across consumer, private equity, and industry."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Clients</p>
      <p class="intro">
        Trusted by leaders across consumer, private equity, and industry.
      </p>

      <!-- One horizontal layer: three groups, gold hairlines between them. -->
      <div class="groups">
        {groups.map((group) => (
          <section class="group">
            <h2 class="group-header">{group.header}</h2>
            <div class="group-cards">
              {group.clients.map((client) => (
                <div class="card">
                  <!-- Fixed-height white tile: every logo scaled to fit
                       inside it, so mixed white backgrounds all read as one
                       matched set and nothing overflows. Decorative — the
                       client name is carried as real text below. -->
                  <div class="logo-tile">
                    <img src={client.logo} alt="" aria-hidden="true" loading="lazy" />
                  </div>
                  <p class="card-name">{client.name}</p>
                  {client.label && <p class="card-label">{client.label}</p>}
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .intro {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.3;
    color: var(--ink);
    max-width: 34ch;
    margin: 1rem 0 0;
  }

  /* --- Groups layer ---
     Mobile-first: the three groups stack vertically, split by gold hairlines.
     On desktop they sit side by side in one row (see media query below). */
  .groups {
    display: flex;
    flex-direction: column;
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }

  .group {
    padding-block: clamp(1.75rem, 5vw, 2.25rem);
  }

  /* Hairline between groups: horizontal while stacked. */
  .group + .group {
    border-top: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
  }

  .group-header {
    font-family: var(--font-body);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.68rem;
    color: var(--gold-deep);
    text-align: center;
    margin: 0 0 1.5rem;
  }

  /* Cards within a group. */
  .group-cards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: start;
    gap: clamp(1rem, 3vw, 1.75rem);
  }

  /* --- Card ---
     Simple top-to-bottom flow, no positioning: tile, gap, name, label.
     Identical structure in every card keeps all names on one baseline. */
  .card {
    width: 150px;
    text-align: center;
  }

  /* The neutral tile every logo shares. A uniform white ground means the
     logos' own white backgrounds blend in instead of showing as boxes. */
  .logo-tile {
    height: 80px;
    padding: 0.85rem 1rem;
    margin-bottom: 1rem; /* clear gap before the name */
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--gold) 20%, transparent);
    display: grid;
    place-items: center;
    overflow: hidden; /* belt-and-braces: nothing escapes the tile */
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  /* Give the image a DEFINITE box (the full padded tile) and let object-fit
     scale the whole logo to fit inside it. `contain` never crops, so tall or
     wide logos (Beyond Snack, Canadian Crystalline) show in full — the earlier
     max-height:100% on an auto-sized grid child wasn't honoured, letting them
     overflow and get clipped by the tile's overflow:hidden. */
  .logo-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    /* Muted greyscale at rest; true colour on hover. */
    filter: grayscale(1);
    opacity: 0.78;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .card:hover .logo-tile img,
  .card:focus-within .logo-tile img {
    filter: grayscale(0);
    opacity: 1;
  }

  .card:hover .logo-tile {
    border-color: color-mix(in srgb, var(--gold) 45%, transparent);
    box-shadow: 0 10px 26px rgba(21, 17, 12, 0.08);
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 1.02rem;
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
  }

  .card-label {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.6rem;
    color: var(--mute-light);
    margin: 0.4rem 0 0;
  }

  /* --- Desktop: one horizontal row, vertical gold hairlines between groups. */
  @media (min-width: 880px) {
    .groups {
      flex-direction: row;
      align-items: stretch;
      justify-content: center;
    }

    .group {
      padding-block: 0;
      padding-inline: clamp(1rem, 2.5vw, 2rem);
    }

    .group:first-child {
      padding-left: 0;
    }

    .group:last-child {
      padding-right: 0;
    }

    /* Hairline becomes vertical between the side-by-side groups. */
    .group + .group {
      border-top: none;
      border-left: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    }

    .group-cards {
      flex-wrap: nowrap;
    }

    /* Slightly smaller, viewport-aware cards so all five fit one row. */
    .card {
      width: clamp(118px, 11vw, 150px);
    }
  }

  /* Reduced motion: colour is simply present, not revealed by a transition. */
  @media (prefers-reduced-motion: reduce) {
    .logo-tile img {
      filter: grayscale(0);
      opacity: 1;
    }
  }
</style>
