---
// About — "Who we are" (a bold serif lede + two short paragraphs) and
// "Why work with us" (three short points). Copy is verbatim from
// askgeko-content.md; keep the text spare — a premium layout wants little.
import Base from '../layouts/Base.astro';
---

<Base
  title="About — Ask GeKo Advisory"
  description="The Leadership Alchemists — a boutique advisory for leaders facing their most consequential decisions."
>
  <!-- Who we are: light section, lots of air. Text left, quiet compass
       mark right — large and faint so it reads as brand, not decoration. -->
  <section class="section who">
    <div class="container who-grid">
      <div class="who-text">
        <p class="eyebrow">Who we are</p>

        <!-- Bold serif lede — one sentence, set large. -->
        <p class="lede">
          The Leadership Alchemists — a boutique advisory for leaders facing
          their most consequential decisions.
        </p>

        <div class="prose">
          <p>
            Ask GeKo Advisory works alongside founders, boards, and executive
            teams at the turning points that define an organisation — the
            strategy that must be reset, the growth that must be rekindled, the
            decision that cannot be undone. Alchemy is our word for what happens
            there: hard problems, worked with rigour and care, transformed into
            outcomes that endure.
          </p>
          <p>
            We are deliberately small, and deliberately hands-on. Every
            engagement is framed with a future-forward lens, AI runs through how
            we think and how we work, and we measure ourselves not by the weight
            of the deck but by the outcomes it sets in motion.
          </p>
        </div>
      </div>

      <!-- Quiet brand mark. Decorative only, so hidden from assistive tech;
           the white logo ground is blended into the bone section and dropped
           to a low opacity so it whispers rather than decorates. -->
      <div class="who-mark" aria-hidden="true">
        <img src="/logo.jpg" alt="" width="360" height="360" />
      </div>
    </div>
  </section>

  <!-- Why work with us: three points on a raised dark surface. -->
  <section class="section why">
    <div class="container">
      <p class="eyebrow eyebrow-dark">Why work with us</p>

      <ul class="points">
        <li>
          <h2>Future-forward.</h2>
          <p>We build for 2030 — not tweak playbooks written for 2020.</p>
        </li>
        <li>
          <h2>AI-native.</h2>
          <p>It is part of who we are and how we work — and what we advise on.</p>
        </li>
        <li>
          <h2>Outcome-linked.</h2>
          <p>We measure our work by the change it creates.</p>
        </li>
      </ul>
    </div>
  </section>
</Base>

<style>
  /* Shared vertical rhythm for page sections. */
  .section {
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  /* --- Who we are (light) --- */
  .who-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  /* Text left, mark right once there's room for both. */
  @media (min-width: 860px) {
    .who-grid {
      grid-template-columns: 1fr auto;
    }
  }

  /* The quiet compass mark. Hidden on narrow screens where there's no room
     for a second column — it's a grace note, never load-bearing. */
  .who-mark {
    display: none;
    justify-self: end;
  }

  .who-mark img {
    width: clamp(240px, 26vw, 360px);
    height: auto;
    /* Blend the logo's white ground into the bone section, then drop the
       whole mark right back so it reads as a faint watermark. */
    mix-blend-mode: multiply;
    opacity: 0.12;
  }

  @media (min-width: 860px) {
    .who-mark {
      display: block;
    }
  }

  .who .lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 1.2;
    color: var(--ink);
    max-width: 26ch;
    margin: 1.25rem 0 2.5rem;
  }

  .prose {
    max-width: 60ch;
  }

  .prose p {
    color: var(--mute-light);
    font-size: 1.05rem;
    margin: 0 0 1.25rem;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  /* --- Why work with us (dark) --- */
  .why {
    background: var(--ink-2);
    color: var(--bone);
  }

  .eyebrow-dark {
    /* On dark, use the brighter gold rather than the deep gold. */
    color: var(--gold);
  }

  .points {
    list-style: none;
    margin: clamp(2.5rem, 6vw, 3.5rem) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* A gold hairline caps each pillar. */
  .points li {
    padding-block: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
  }

  .points li:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
  }

  .points h2 {
    /* Sized so the hyphenated headings ("Future-forward.", "Outcome-linked.")
       sit on one line within the narrow columns. */
    font-size: clamp(1.45rem, 2.5vw, 1.6rem);
    color: var(--bone);
    margin: 0 0 1rem;
  }

  .points p {
    margin: 0;
    max-width: 30ch;
    color: var(--mute-dark);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  /* Wider screens: three narrow "monuments", not a cramped row. Narrow
     columns with generous gaps, top-aligned; real vertical depth between the
     hairline cap and the heading, then supporting text left to run 2–3 lines. */
  @media (min-width: 800px) {
    .points {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: flex-start;
      column-gap: clamp(2.5rem, 6vw, 5rem);
      row-gap: 2.5rem;
    }

    .points li {
      flex: 0 1 13rem;
      padding-block: 3rem 0;
      border-bottom: none;
    }

    .points li:last-child {
      border-bottom: none;
    }
  }
</style>
